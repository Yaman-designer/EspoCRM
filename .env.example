# ─────────────────────────────────────────────────────────────
# EspoCRM Backend (SERVER-ONLY — no NEXT_PUBLIC_ prefix)
# All client requests go through the /api/espo proxy route.
# The real API URL is never sent to the browser.
# ─────────────────────────────────────────────────────────────
ESPO_API_URL=https://your-espocrm.example.com/api/v1

# ─────────────────────────────────────────────────────────────
# NextAuth
# Generate a secure secret: openssl rand -base64 32
# MUST be changed before deploying to production.
# ─────────────────────────────────────────────────────────────
AUTH_SECRET=REPLACE_WITH_SECURE_RANDOM_32_CHAR_STRING

# Full URL of your deployed app (no trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app
