# ─────────────────────────────────────────────────────────────
# EspoCRM Backend (SERVER-ONLY — no NEXT_PUBLIC_ prefix)
# All client requests go through the /api/espo proxy route.
# The real API URL is never sent to the browser.
# ─────────────────────────────────────────────────────────────
ESPO_API_URL=https://staging.realtorvoice.gr/api/v1

# ─────────────────────────────────────────────────────────────
# NextAuth
# Generate a secure secret: openssl rand -base64 32
# MUST be changed before deploying to production.
# ─────────────────────────────────────────────────────────────
AUTH_SECRET=change-this-to-a-secure-random-string-in-production

# Full URL of your deployed app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Maps & Geocoding (OPTIONAL — all public client-side keys)
# Without these, the system falls back to OpenStreetMap Nominatim
# for geocoding and Overpass API for nearby places (both free).
# ─────────────────────────────────────────────────────────────

# Google Maps API key — enables higher-accuracy geocoding.
# Restrict this key to HTTP referrers in the Google Cloud Console.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Country appended to every geocoding query to improve accuracy.
# Change this if deploying the CRM for a different country.
NEXT_PUBLIC_GEOCODING_COUNTRY=Greece
